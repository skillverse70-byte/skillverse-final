{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "participant_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skill_swap_id": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "participant_ids"
  ]
}