DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-this-secret-key
DEBUG=True
TIME_ZONE=Africa/Nairobi
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

MYSQL_DATABASE=skillverse
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CHANNEL_LAYER_BACKEND=channels.layers.InMemoryChannelLayer

EMAIL_BACKEND=anymail.backends.resend.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@skillverse.local
SERVER_EMAIL=noreply@skillverse.local
FRONTEND_APP_URL=http://localhost:5173
RESEND_API_KEY=re_replace_with_your_resend_key
CHAPA_ENV=test
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_ENCRYPTION_KEY=
CHAPA_RETURN_URL=http://localhost:5173/courses/{course_id}?payment_tx_ref={tx_ref}
CHAPA_CALLBACK_URL=http://localhost:8000/api/payments/chapa/callback/
CHAPA_HTTP_TIMEOUT_SECONDS=15
AI_DEFAULT_PROVIDER=openrouter
AI_FEATURES_ENABLED=False
AI_RECOMMENDATIONS_ENABLED=False
AI_ASSIGNMENT_FEEDBACK_ENABLED=False
AI_COGNITIVE_MONITORING_ENABLED=False
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemma-3n-e4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai
OPENROUTER_HTTP_TIMEOUT_SECONDS=20
OPENROUTER_APP_TITLE=SkillVerse
OPENROUTER_APP_REFERER=http://localhost:5173
PAYMENT_RATE_THROTTLE=20/hour
ENABLE_AUTH_THROTTLING=False

JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
AUTH_RATE_THROTTLE=20/hour
AUTH_LOGIN_RATE_THROTTLE=10/hour
AUTH_REGISTER_RATE_THROTTLE=5/hour
AUTH_VERIFY_EMAIL_RATE_THROTTLE=10/hour
AUTH_PASSWORD_RESET_RATE_THROTTLE=5/hour
AUTH_ORGANIZATION_REGISTER_RATE_THROTTLE=3/hour

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
